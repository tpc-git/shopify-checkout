# ============================================================
# Shopify Checkout Notifier: environment variables
# Local: copy this file to .env.local and fill it in.
# Vercel: Project -> Settings -> Environment Variables.
# Secrets live only on the server, never in the browser.
# ============================================================

# ---------- Database (Neon Postgres) ----------
# Pooled connection string from the Neon dashboard (used as fallback).
DATABASE_URL=
# Optional: direct (non-pooler) URL for read-your-writes consistency. If unset,
# the app strips "-pooler" from DATABASE_URL automatically. On Vercel + Neon,
# POSTGRES_URL_NON_POOLING is also recognized.
# DATABASE_URL_UNPOOLED=

# ---------- Shopify ----------
# Store domain (the .myshopify.com one), e.g. tacoma-truckparts.myshopify.com
# Used for both the token endpoint and Admin API calls.
SHOPIFY_STORE_DOMAIN=

# App credentials (Dev Dashboard / custom app). The app exchanges these for a
# 24h Admin API token via the client credentials grant at runtime.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Webhook signing secret. For webhooks registered by the app this is the app's
# client secret (= SHOPIFY_API_SECRET). For webhooks created manually in the
# admin, use the signing secret shown on the Webhooks page.
SHOPIFY_WEBHOOK_SECRET=

# Optional: a static Admin API token (e.g. an offline authorization-code-grant
# token, or a legacy custom-app shpat_...). If set, it takes precedence over the
# client credentials grant. Leave blank to use SHOPIFY_API_KEY/SECRET instead.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Public storefront domain used to build product/checkout links in messages,
# e.g. tacoma-truckparts.com
SHOPIFY_STOREFRONT_DOMAIN=tacoma-truckparts.com

# ---------- Telegram ----------
# Bot token from @BotFather. Add the bot to your managers' group chat and set
# the group chat ID in the in-app Settings page (one message per checkout,
# edited in place as new details arrive).
TELEGRAM_BOT_TOKEN=

# ---------- Quo (customer SMS; formerly OpenPhone) ----------
# API key from Quo Settings -> API. Authorization header uses the raw key.
QUO_API_KEY=

# Sender Quo phone number in E.164 format, e.g. +12065551234
QUO_FROM_NUMBER=

# ---------- Vercel Blob (unused while MMS is disabled) ----------
# Kept for a future cart-image MMS re-enable. Not required for Quo SMS.
# BLOB_READ_WRITE_TOKEN=

# ---------- App ----------
# Public base URL of this deployment, e.g. https://checkout.tacoma-truckparts.com
# Used for "Open checkout" links in Telegram/SMS and as the QStash callback base.
APP_URL=

# ---------- QStash (delayed notification) ----------
# From the Upstash QStash console. Callback: {APP_URL}/api/qstash/notify
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Seconds to wait after checkout creation before sending the first notification (default 120).
NOTIFY_DELAY_SECONDS=120

# Seconds to wait before sending after-hours customer SMS (default 300 = 5 minutes).
# Callback: {APP_URL}/api/qstash/sms — skipped if checkout completed in the meantime.
SMS_DELAY_SECONDS=300

# TEMPORARY — redirect qualifying customer SMS to this E.164 (checkout phone still required).
# Unset to send to real customers. Delete after testing.
# SMS_OVERRIDE_TO=+19737766152

# ---------- Vercel Cron ----------
# Auth for scheduled cron routes. Generate a random secret; set the same value in Vercel env vars.
CRON_SECRET=
